import { Button } from "std-widgets.slint";
import { Command } from "waybruh/globals.slint";

export component BruhBar inherits Window {
    // width: 2520px;
    height: 25px;

    default-font-size: 12pt;

    HorizontalLayout {
        Button {
            width: 100%;
            text: "Hello, World";
            clicked => {
                self.text = Command.execute(["head", "-c", "8", "/dev/random"]).stdout;
            }
        }
        Button {
            width: 100%;
            text: "Hello, World";
            clicked => {
                self.text = Command.execute(["head", "-c", "8", "/dev/random"]).stdout;
            }
        }
    }
}
