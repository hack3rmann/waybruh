import { Button } from "std-widgets.slint";
import { Command } from "waybruh/globals.slint";

export component BruhBar inherits Window {
    default-font-size: 16pt;

    property <string> text: "hello, world";

    HorizontalLayout {
        Text {
            text: root.text;
            color: black;
            font-size: 24pt;
        }

        Button {
            clicked => {
                root.text = Command.execute(["head", "-c", "8", "/dev/random"]).stdout;
            }
        }
    }
}
