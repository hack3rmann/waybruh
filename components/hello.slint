import { Button } from "std-widgets.slint";
import { Command } from "waybruh/globals.slint";

export component BruhBar inherits Window {
    title: "Waybruh";
    preferred-height: 50px;

    default-font-size: 12pt;

    HorizontalLayout {
        Button {
            width: 100%;
            text: "Hello, World";
            clicked => {
                self.text = root.width / 1px;
            }
        }
        Button {
            width: 100%;
            text: "Hello, World";
            clicked => {
                self.text = root.height / 1px;
            }
        }
    }
}
