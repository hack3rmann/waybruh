import { Button } from "std-widgets.slint";
import { Shell } from "waybruh-globals.slint";

export component BruhBar inherits Window {
    width: 100px;
    height: 100px;

    HorizontalLayout {
        Text {
            text: "hello world";
            color: black;
            font-size: 24pt;
        }

        Button {
            clicked => {
                Shell.execute("notify-send \"Button's is clicked\"")
            }
        }
    }
}
