import { Button } from "std-widgets.slint";
import { Bar } from "waybruh/bar.slint";

export component BruhBar inherits Bar {
    exclusive-zone: 15px;
    default-font-size: 8pt;
    default-font-family: "JetBrainsMono Nerd Font";

    VerticalLayout {
        alignment: start;

        HorizontalLayout {
            // Match drawn content's height to the exclusive zone
            height <=> root.exclusive-zone;

            VerticalLayout {
                alignment: center;

                Text {
                    text: "Hello, World";
                    color: white;
                }
            }
        }
    }
}
