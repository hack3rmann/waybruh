import { Button } from "std-widgets.slint";
import { Command } from "waybruh/globals.slint";
import { Bar } from "waybruh/bar.slint";

export component BruhBar inherits Bar {
    // Windows will avoid only this part of the surface
    exclusive-zone: 50phx;

    default-font-size: 12pt;

    VerticalLayout {
        alignment: start;

        HorizontalLayout {
            // Match drawn content's height to the exclusive zone
            height <=> root.exclusive-zone;

            Button {
                width: 50%;

                clicked => {
                    self.text = root.width / 1px;
                    root.exclusive-zone = 100px;
                }
            }

            Button {
                width: 50%;

                clicked => {
                    self.text = root.height / 1px;
                    popup.show();
                }
            }
        }
    }

    popup := PopupWindow {
        Rectangle {
            height: 100%;
            width: 100%;
            background: yellow;
        }

        x: 200px;
        y: 200px;
        height: 50px;
        width: 50px;
    }
}
