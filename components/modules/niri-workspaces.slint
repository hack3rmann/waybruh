import { Niri, String } from "../waybruh/globals.slint";

component Workspace inherits Rectangle {
    in property <bool> is-active;
    in property <string> index;

    in-out property <color> active-color: whitesmoke;
    in-out property <color> non-active-color: #6e6a86;

    Text {
        text: String.indian-to-roman(index);
        color: is-active ? active-color : non-active-color;

        animate color { duration: 200ms; }
    }

    opacity: 0;

    animate opacity {
        duration: 400ms;
        easing: ease-in;
    }

    animate x {
        duration: 600ms;
        easing: ease-out-bounce;
    }

    animate y {
        duration: 200ms;
        easing: ease-out-quad;
    }

    init => {
        self.opacity = 1;
        self.y = 0;
    }
}

export component NiriWorkspaces inherits Rectangle {
    property <length> item-width: 8pt;
    property <length> item-spacing: 8pt;

    width: Niri.workspaces.length * (item-width + item-spacing) - item-spacing;

    for niri-workspace[i] in Niri.workspaces: Workspace {
        x: i * (item-width + item-spacing);
        y: -20px;
        width: item-width;

        is-active: niri-workspace.is-active;
        index: niri-workspace.index;
    }
}
