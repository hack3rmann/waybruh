import { Date, Hyprland } from "waybruh/globals.slint";
import { Time } from "modules/time.slint";
import { OpaqueSeparator, DottedSeparator } from "modules/separators.slint";

component Modules inherits HorizontalLayout {
    @children
}

export component ModulesLeft inherits Modules {
    alignment: start;
    padding-left: 6px;

    property <bool> entered-fullscreen <=> Hyprland.entered-fullscreen;

    text := Text {
        text: "not fullscreen";
        color: white;
    }

    changed entered-fullscreen => {
        if (entered-fullscreen) {
            text.text = "fullscreen";
        } else {
            text.text = "not fullscreen";
        }
    }
}

export component ModulesCenter inherits Modules {
    alignment: center;

    DottedSeparator { }
    Time { }
    OpaqueSeparator { }
}

export component ModulesRight inherits Modules {
    alignment: end;
    padding-right: 6px;

    Text {
        text: "Modules Right";
        color: white;
    }
}
