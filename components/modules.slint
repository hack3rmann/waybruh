import { Date, Hyprland } from "waybruh/globals.slint";
import { Time } from "modules/time.slint";
import { OpaqueSeparator, DottedSeparator } from "modules/separators.slint";

component Modules inherits HorizontalLayout {
    @children
}

export component ModulesLeft inherits Modules {
    alignment: start;
    padding-left: 6px;

    property <string> title <=> Hyprland.active-window-title;
    property <string> class <=> Hyprland.active-window-class;

    text_class := Text {
        text: "";
        color: white;
    }

    DottedSeparator { }

    text_title := Text {
        text: "";
        color: white;
    }

    changed title => {
        text_title.text = title;
    }

    changed class => {
        text_class.text = class;
    }
}

export component ModulesCenter inherits Modules {
    alignment: center;

    DottedSeparator { }
    Time { }
    OpaqueSeparator { }
}

export component ModulesRight inherits Modules {
    alignment: end;
    padding-right: 6px;

    Text {
        text: "Modules Right";
        color: white;
    }
}
